<style>
html {
  scroll-behavior: smooth;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: Arial, sans-serif;
  line-height: 1.6;
  background-color: #f4f4f4;
  color: #333;
  background-image: url("backgroundoption2.jpg");;
  background-size: 100%
}

.container {
  width: 100%;
  margin: 0 auto;
}

/* Header */
header {
  background: black;
  color: white;
  padding: 40px 0;
  position: fixed;
  width: 100%;
  top: 0;
  z-index: 100;
  height: 5%;
}

header h1 {
  float: left;
  margin-left: 20px;
  margin-top: -20px;
}

header nav ul {
  list-style: none;
  float: right;
  margin-right: 20px;
  margin-top: -10px;
}

header nav ul li {
  display: inline;
  margin-left: 20px;
  
}

header nav ul li a {
  color: white;
  text-decoration: none;
}

/* Sections */
section {
  padding: 40px 0;
}

section h2 {
  text-align: center;
  margin-bottom: 20px;
}

section p {
  text-align: center;
  font-size: 1.1em;
}

/* Portfolio Gallery */
.gallery {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
}

.gallery .item {
  width: 25%;
  margin-bottom: 10px;
}

.gallery .item img video{
  width: 100%;
  height: auto;
  border-radius: 5px;
  border: 10px solid black;
  
}

.gallery .item p {
  text-align: center;
  margin-top: 10px;
}

.img {
float: right;
margin-right: 90px;
margin-top: -100px;
}
img {
border: 5px solid black;
}

/* Footer */
footer {
  background: black;
  color: #fff;
  text-align: center;
  padding: 10px 0;
  }
  
