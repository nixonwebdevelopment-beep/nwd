.fade-in-image {
  opacity: 0;
  transition: opacity 1s ease-in-out;
}

.fade-in-image.visible {
  opacity: 1;
}
.animate-on-scroll.active {
  opacity: 1;
}

.animate-on-scroll span {
  opacity: 0;
  transition: opacity 1s ease, transform 1s ease;
}

.animate-on-scroll.active span {
  opacity: 1;
}



